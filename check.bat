@echo off
echo ========================================
echo 1. ПЕРЕВІРКА БЕКЕНДУ (Ruff)
echo ========================================
cd backend
ruff check .
if %ERRORLEVEL% NEQ 0 goto error

echo ========================================
echo 2. ТИПІЗАЦІЯ БЕКЕНДУ (Mypy)
echo ========================================
mypy .
if %ERRORLEVEL% NEQ 0 goto error
cd ..

echo ========================================
echo 3. ПЕРЕВІРКА ФРОНТЕНДУ (ESLint)
echo ========================================
cd frontend
call npm run lint
if %ERRORLEVEL% NEQ 0 goto error

echo ========================================
echo 4. ЗБІРКА ТА ТИПІЗАЦІЯ ФРОНТЕНДУ (Vite/TS)
echo ========================================
call npm run build
if %ERRORLEVEL% NEQ 0 goto error
cd ..

echo ========================================
echo УСІ ПЕРЕВІРКИ ПРОЙДЕНО УСПІШНО! МОЖНА РОБИТИ КОМІТ.
echo ========================================
pause
exit /b 0

:error
echo ========================================
echo ЗНАЙДЕНО ПОМИЛКИ! Виправте їх перед комітом.
echo ========================================
cd ..
pause
exit /b 1